# =========================
# Application
# =========================
SERVICE_NAME=auth-service
SERVICE_VERSION=1.0.0
APP_ENV=development          # development, staging, production
APP_DEBUG=true               # true/false
APP_URL=http://localhost:8070

# =========================
# HTTP Server
# =========================
HTTP_HOST=0.0.0.0
HTTP_PORT=8070

# =========================
# Database (PostgreSQL)
# =========================
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=multilang1
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Tashkent
DB_MAX_OPEN_CONNS=20
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=60s

# =========================
# Redis (session/cache)
# =========================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =========================
# JWT Configuration
# =========================
JWT_SECRET=my_super_secret_key_12345  # productionda random va uzunroq bo‘lsin
JWT_EXPIRED=3600                      # 1 soat
JWT_REFRESH_EXPIRED=86400             # 1 kun

# =========================
# CORS (frontend bilan ishlash uchun)
# =========================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type

# =========================
# Logging
# =========================
LOG_LEVEL=debug   # debug, info, warn, error
LOG_FORMAT=json   # text yoki json

# =========================
# Email (email verification va password reset uchun)
# =========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=abdugofforqodirov19@gmail.com
SMTP_PASSWORD=vipycxngkwwrpggi
SMTP_FROM="DevKadirov"

# =========================
# RabbitMQ (agar microservices orasida ishlatilsa)
# =========================
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# =========================
# Monitoring / Metrics
# =========================
PROMETHEUS_PORT=9090
HEALTHCHECK_PATH=/health
